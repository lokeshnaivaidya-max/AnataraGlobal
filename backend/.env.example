PORT=5001
NODE_ENV=development
DB_USER=
DB_PASSWORD=
DB_HOST=
DB_NAME=
DB_PORT=

# Database Connection (PostgreSQL)
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
# Change user, password, host, port, and database name as per your local PostgreSQL setup
DATABASE_URL="postgresql://user:password@localhost:5432/anatara?schema=public"
DIRECT_URL="postgresql://user:password@localhost:5432/anatara?schema=public"

# JWT Authentication
JWT_SECRET="change-this-to-a-random-secret-in-production"
JWT_EXPIRES_IN="7d"

# OTP Configuration
OTP_EXPIRES_IN_MINS=10

# SMTP Configuration (for Module 8 Email Notifications)
# Configure these with your real provider (e.g. SendGrid, Mailgun, or standard Gmail SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM="Antara <your-email@gmail.com>"

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:5001/api/v1/auth/google/callback
FRONTEND_URL=http://localhost:5173
